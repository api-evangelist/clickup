    "_postman_id": "b80f4eae-3bc1-4630-b947-122a8c8d06dd",
    "name": "ClickUp Folders API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "The ClickUp Folders API provides endpoints for managing Folders, which are optional organizational containers that sit between Spaces and Lists in the ClickUp hierarchy. Folders group related Lists together and can be used to organize projects or workstreams within a Space. Developers can create, update, delete, and retrieve Folders and their associated Lists.\n\nContact Support:\n Name: ClickUp Support",
      "type": "text/plain"
    }
  }
