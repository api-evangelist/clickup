    "_postman_id": "2a7baf6e-2e39-4afa-9bed-1328b24b90cd",
    "name": "ClickUp Teams (Workspaces) API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "The ClickUp Teams API provides access to Workspace-level information and membership. In the ClickUp API, Teams correspond to Workspaces, which are the top-level organizational unit. The API allows developers to retrieve a list of Workspaces the authenticated user belongs to, along with member details and roles. This is typically the starting point for navigating the ClickUp hierarchy.\n\nContact Support:\n Name: ClickUp Support",
      "type": "text/plain"
    }
  }
